{
  "version": 2,
  "name": "dmt-website-frontend",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "https://dmt-website-backend.onrender.com/api"
  },
  "build": {
    "env": {
      "VITE_API_URL": "https://dmt-website-backend.onrender.com/api"
    }
  }
}