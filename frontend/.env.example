# ═══════════════════════════════════════
# DMT WEBSITE FRONTEND - ENVIRONMENT TEMPLATE
# ═══════════════════════════════════════
# Copy this file to .env and fill in your actual values

# ── API CONFIGURATION ──
# Development: http://localhost:5000/api
# Production: https://your-backend-url.com/api
VITE_API_URL=http://localhost:5000/api

# ── IMPORTANT NOTES ──
# 1. All environment variables must be prefixed with VITE_ for Vite to expose them
# 2. Never commit .env file to version control
# 3. In production, set these variables in your hosting platform (Vercel, Netlify, etc.)
# 4. The .env file is for local development only